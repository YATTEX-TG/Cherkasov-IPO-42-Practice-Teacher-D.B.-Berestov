<Window x:Class="CherkasovApp.SaleDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование продажи" Height="300" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Наименование продукции -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Продукция:" 
                   VerticalAlignment="Center" Margin="5"/>
        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="ProductComboBox" 
                  DisplayMemberPath="Name" SelectedValuePath="Id"
                  Margin="5" Padding="3"/>

        <!-- Количество -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Количество:" 
                   VerticalAlignment="Center" Margin="5"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="QuantityTextBox" 
                 Margin="5" Padding="3" PreviewTextInput="NumberValidationTextBox"/>

        <!-- Дата продажи -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Дата продажи:" 
                   VerticalAlignment="Center" Margin="5"/>
        <DatePicker Grid.Row="2" Grid.Column="1" x:Name="SaleDatePicker" 
                    Margin="5" Padding="3" SelectedDateFormat="Short"/>

        <!-- Сумма (автоматически) -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Сумма:" 
                   VerticalAlignment="Center" Margin="5"/>
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="TotalAmountTextBox" 
                 Margin="5" Padding="3" IsReadOnly="True" 
                 Background="#F0F0F0" Foreground="Blue"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="5">
            <Button x:Name="SaveButton" Content="Сохранить" Width="80" 
                    Margin="5" Click="SaveButton_Click" IsDefault="True"/>
            <Button x:Name="CancelButton" Content="Отмена" Width="80" 
                    Margin="5" Click="CancelButton_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>