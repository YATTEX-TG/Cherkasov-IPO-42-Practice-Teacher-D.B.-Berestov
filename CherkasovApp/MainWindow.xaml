<Window x:Class="CherkasovApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Учет партнеров - Cherkasov" 
        Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Меню -->
        <Menu Grid.Row="0">
            <MenuItem Header="_Файл">
                <MenuItem Header="_Открыть" Click="OpenMenuItem_Click"/>
                <MenuItem Header="_Импорт" Click="ImportMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="_Сохранить" Click="SaveMenuItem_Click"/>
                <MenuItem Header="Сохранить _как">
                    <MenuItem Header="В _TXT" Click="SaveAsTxtMenuItem_Click"/>
                    <MenuItem Header="В _Excel (CSV)" Click="SaveAsExcelMenuItem_Click"/>
                    <MenuItem Header="В _JSON" Click="SaveAsJsonMenuItem_Click"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Выход" Click="ExitMenuItem_Click"/>
            </MenuItem>
            <MenuItem Header="_Партнеры">
                <MenuItem Header="_Добавить партнера" Click="AddPartnerMenuItem_Click"/>
                <MenuItem Header="_Редактировать партнера" Click="EditPartnerMenuItem_Click"/>
                <MenuItem Header="_Удалить партнера" Click="DeletePartnerMenuItem_Click"/>
            </MenuItem>
            <MenuItem Header="_Продажи">
                <MenuItem Header="_Добавить продажу" Click="AddSaleMenuItem_Click"/>
                <MenuItem Header="_Редактировать продажу" Click="EditSaleMenuItem_Click"/>
                <MenuItem Header="_Удалить продажу" Click="DeleteSaleMenuItem_Click"/>
            </MenuItem>
            <MenuItem Header="_Статистика" Click="StatisticsMenuItem_Click"/>

            <!-- Новая вкладка ПРАВИЛА -->
            <MenuItem Header="_Правила" Click="RulesMenuItem_Click"/>

            <MenuItem Header="_Справка">
                <MenuItem Header="О _проекте" Click="AboutMenuItem_Click"/>
            </MenuItem>
        </Menu>

        <!-- Основная область -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель - список партнеров -->
            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" CornerRadius="5">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Партнеры" FontWeight="Bold" FontSize="16" 
                               HorizontalAlignment="Center" Margin="5"/>
                    <ListBox x:Name="PartnersListBox" SelectionMode="Single" 
                             SelectionChanged="PartnersListBox_SelectionChanged"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="5">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" 
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Director}" Foreground="Gray"/>
                                        <TextBlock Text="{Binding Phone}" Foreground="Gray"/>
                                        <TextBlock Text="{Binding Address}" Foreground="Gray" FontSize="10"/>
                                        <StackPanel Orientation="Horizontal" 
                                                    HorizontalAlignment="Right">
                                            <TextBlock Text="Рейтинг: " Foreground="Gray"/>
                                            <TextBlock Text="{Binding Rating}" Foreground="Gray"/>
                                            <TextBlock Text=" | Скидка: " Foreground="Gray"/>
                                            <TextBlock Text="{Binding Discount}" 
                                                       Foreground="Green" FontWeight="Bold"/>
                                            <TextBlock Text="%" Foreground="Gray"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Добавить партнера" Click="AddPartnerMenuItem_Click"/>
                                <MenuItem Header="Редактировать партнера" Click="EditPartnerMenuItem_Click"/>
                                <MenuItem Header="Удалить партнера" Click="DeletePartnerMenuItem_Click"/>
                                <Separator/>
                                <MenuItem Header="Добавить продажу" Click="AddSaleMenuItem_Click"/>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Разделитель -->
            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" 
                         Background="LightGray" Width="5"/>

            <!-- Правая панель - список продаж -->
            <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="1" CornerRadius="5">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="История реализации продукции" 
                               FontWeight="Bold" FontSize="16" 
                               HorizontalAlignment="Center" Margin="5"/>
                    <DataGrid x:Name="SalesDataGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              Margin="5" HeadersVisibility="Column" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Наименование продукции" 
                            Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Количество" 
                            Binding="{Binding Quantity}" Width="100"/>
                            <DataGridTextColumn Header="Дата продажи" 
                            Binding="{Binding SaleDate, StringFormat={}{0:dd.MM.yyyy}}" 
                            Width="120"/>
                            <DataGridTextColumn Header="Сумма" 
                    Binding="{Binding TotalAmount, StringFormat={}{0:N0} ₽}" 
                    Width="120"/>
                        </DataGrid.Columns>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Height" Value="25"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="LightBlue"/>
                                        <Setter Property="BorderBrush" Value="DarkBlue"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Добавить продажу" Click="AddSaleMenuItem_Click"/>
                                <Separator/>
                                <MenuItem Header="Редактировать продажу" Click="EditSaleMenuItem_Click"/>
                                <MenuItem Header="Удалить продажу" Click="DeleteSaleMenuItem_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>